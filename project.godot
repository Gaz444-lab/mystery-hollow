; Engine configuration file.
; Mystery Hollow — open-world detective life simulator
; Godot 4.3+

config_version=5

[application]

config/name="Mystery Hollow"
config/description="Open-world detective life simulator set in a cozy small town."
config/version="0.1.0"
run/main_scene="res://scenes/main/MainMenu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://assets/ui/icon.svg"

[autoload]

EventBus="*res://scripts/autoload/EventBus.gd"
GameState="*res://scripts/autoload/GameState.gd"
EraManager="*res://scripts/autoload/EraManager.gd"
SaveSystem="*res://scripts/autoload/SaveSystem.gd"
TimeSystem="*res://scripts/autoload/TimeSystem.gd"
CaseManager="*res://scripts/autoload/CaseManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

